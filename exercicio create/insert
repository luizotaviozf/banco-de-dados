-- =====================================================
-- 1) CRIAÇÃO DAS TABELAS
-- =====================================================

-- -----------------------------------------------------
-- TABELA CIDADE
-- Forma 1: PK definida ao final do CREATE TABLE
-- -----------------------------------------------------

CREATE TABLE cidade (
    codigo INTEGER,
    nome VARCHAR(100) NOT NULL,
    uf CHAR(2),
    regiao VARCHAR(50),

    CONSTRAINT pk_cidade PRIMARY KEY (codigo)
);

-- -----------------------------------------------------
-- TABELA CIDADE
-- Forma 2: PK definida na mesma linha do atributo
-- (DEIXAR COMENTADA)
-- -----------------------------------------------------

