-- -----------------------------------------------------
-- TABELA PROFESSOR
-- -----------------------------------------------------

CREATE TABLE professor (
    codigo INTEGER,
    nome VARCHAR(100) NOT NULL,
    RG VARCHAR(20) UNIQUE,
    sexo CHAR(1) DEFAULT 'M',
    codCid INTEGER,

    CONSTRAINT pk_professor PRIMARY KEY (codigo),

    CONSTRAINT fk_professor_cidade
        FOREIGN KEY (codCid)
        REFERENCES cidade(codigo),

    CONSTRAINT ck_professor_sexo
        CHECK (sexo IN ('F', 'M'))
);

-- -----------------------------------------------------
-- TABELA ALUNO
-- -----------------------------------------------------

CREATE TABLE aluno (
    codigo INTEGER,
    nome VARCHAR(100) NOT NULL,
    dtaNasc DATE,
    sexo CHAR(1) DEFAULT 'M',
    RG VARCHAR(20) UNIQUE,
    codCid INTEGER,

    CONSTRAINT pk_aluno PRIMARY KEY (codigo),

    CONSTRAINT fk_aluno_cidade
        FOREIGN KEY (codCid)
        REFERENCES cidade(codigo),

    CONSTRAINT ck_aluno_sexo
        CHECK (sexo IN ('F', 'M'))
);

-- -----------------------------------------------------
-- TABELA AULA
-- -----------------------------------------------------

CREATE TABLE aula (
    codAlu INTEGER,
    codProf INTEGER,
    dtaInicio DATE,
    dtaFim DATE,

    CONSTRAINT pk_aula
        PRIMARY KEY (codAlu, codProf, dtaInicio),

    CONSTRAINT fk_aula_aluno
        FOREIGN KEY (codAlu)
        REFERENCES aluno(codigo),

    CONSTRAINT fk_aula_professor
        FOREIGN KEY (codProf)
        REFERENCES professor(codigo)
);

-- -----------------------------------------------------
-- TABELA RENDIMENTO
-- -----------------------------------------------------

CREATE TABLE rendimento (
    codAlu INTEGER,
    codProf INTEGER,
    dtaInicio DATE,
    observacoes VARCHAR(255),
    aproveitamento VARCHAR(20) DEFAULT 'Bom',

    CONSTRAINT pk_rendimento
        PRIMARY KEY (codAlu, codProf, dtaInicio),

    CONSTRAINT fk_rendimento_aula
        FOREIGN KEY (codAlu, codProf, dtaInicio)
        REFERENCES aula(codAlu, codProf, dtaInicio),

    CONSTRAINT ck_aproveitamento
        CHECK (aproveitamento IN ('Excelente', 'Bom', 'Ruim'))
);

-- =====================================================
-- 2) ALTER TABLE
-- =====================================================

-- -----------------------------------------------------
-- a) Adicionar coluna contato na tabela aluno
-- -----------------------------------------------------

ALTER TABLE aluno
ADD contato VARCHAR(100);

-- -----------------------------------------------------
-- b) Alterar tabela cidade
-- i) default SC na UF
-- ii) deletar coluna regiao
-- iii) adicionar regiao_nacional
-- -----------------------------------------------------

ALTER TABLE cidade
    ALTER COLUMN uf SET DEFAULT 'SC';

ALTER TABLE cidade
    DROP COLUMN regiao;

ALTER TABLE cidade
    ADD regiao_nacional VARCHAR(50);

